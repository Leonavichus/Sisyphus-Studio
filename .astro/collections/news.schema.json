{
  "$ref": "#/definitions/news",
  "definitions": {
    "news": {
      "type": "object",
      "properties": {
        "isoDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "errorMessage": {
            "pattern": "Must be YYYY-MM-DD"
          }
        },
        "image": {
          "type": "string",
          "pattern": "^\\/images\\/"
        },
        "type": {
          "type": "string",
          "enum": [
            "announcement",
            "dev-diary",
            "update"
          ],
          "default": "update"
        },
        "en": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "date": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "body": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "title",
            "date",
            "summary",
            "body"
          ],
          "additionalProperties": false
        },
        "ru": {
          "$ref": "#/definitions/news/properties/en"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "isoDate",
        "image",
        "en",
        "ru"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}